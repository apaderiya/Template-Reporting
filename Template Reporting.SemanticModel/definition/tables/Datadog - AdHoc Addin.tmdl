	partition 'Datadog - AdHoc Addin' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH",[Implementation="2.0"]){[Name="PROD_RAW"]}[Data], "with prod_tenant_info as #(lf)(#(lf)select#(lf)data_cntr_cd,#(lf)tenant_id,#(lf)account_id,#(lf)tenant_nm#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm in ('PRODUCTION')#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf)),#(lf)#(lf)adhoc_enabled as#(lf)(#(lf)select distinct#(lf)concat(data_center,'.',tenant_id) as vh_tenant_id,#(lf)CONTRIBUTOR_ADHOC_ENABLED#(lf)from PROD_RAW.MT_SERVER.MTSERVER_TENANT_SETTINGS_STAGING#(lf)where contributor_adhoc_enabled = 'TRUE' #(lf)    OR tenant_id IN ('631326086198067200', '928495359901696000')#(lf)),#(lf)#(lf)user_info as #(lf)(#(lf)select distinct#(lf)tenant_dc,#(lf)user_id,#(lf)case when #(lf)((login_email ilike '%vena%' or ntfctn_email ilike '%vena%') #(lf)or (last_impersonation_login_dt is not null and admin_access_ind = 'Y' and built_in_admin_accnt = 'Y'))#(lf)then 'Y' else null end as consultant_login,#(lf)case#(lf)when (admin_access_ind = 'Y' or mdlr_access_ind = 'Y' or mngr_access_ind = 'Y') then 'power user'#(lf)when (admin_access_ind = 'N' and mdlr_access_ind = 'N' and mngr_access_ind = 'N' and cntrbtr_access_ind = 'Y') then 'business user'#(lf)end as user_type#(lf)from PROD_HARMONIZED.PRODUCT.VW_USER_PROF_EML_INCLD users#(lf)inner join prod_tenant_info #(lf)    on concat(prod_tenant_info.data_cntr_cd, '.', prod_tenant_info.tenant_id) = users.tenant_dc#(lf)where crnt_rcrd_ind = 'Y'#(lf)),#(lf)#(lf)original_rows as#(lf)(#(lf)select#(lf)customer_id as tenant_id,#(lf)tenant_nm,#(lf)account_id,#(lf)CONTRIBUTOR_ADHOC_ENABLED,#(lf)region as vena_hub,#(lf)concat(region,'.',customer_id) as dc_tenant_id, #(lf)staging.user_id,#(lf)user_type,#(lf)action_datetime,#(lf)auth_type,#(lf)file_id, #(lf)office_version,#(lf)total_intersections,#(lf)refresh_duration/1000 as refresh_duration_sec#(lf)from PROD_RAW.PROD_TEAM_SANDBOX.ADHOC_RUM_DATA_STAGING staging #(lf)inner join prod_tenant_info #(lf)    on concat(region,'.',customer_id) = concat(data_cntr_cd,'.',tenant_id)#(lf)left join user_info #(lf)    on concat(region,'.',customer_id) = user_info.tenant_dc #(lf)   and staging.user_id = user_info.user_id #(lf)left join adhoc_enabled #(lf)    on vh_tenant_id = concat(region,'.',customer_id)#(lf)),#(lf)#(lf)abbott_rum_rows as#(lf)(#(lf)    select #(lf)    staging.customer_id as tenant_id,#(lf)    'Abbott Established Pharmaceuticals' as tenant_nm,#(lf)    '0011O00002G24Yc' as account_id,#(lf)    null as CONTRIBUTOR_ADHOC_ENABLED,#(lf)    staging.region as vena_hub,#(lf)    concat(staging.region,'.',staging.customer_id) as dc_tenant_id, #(lf)    staging.user_id,#(lf)    null as user_type,#(lf)    staging.action_datetime,#(lf)    staging.auth_type,#(lf)    staging.file_id, #(lf)    staging.office_version,#(lf)    staging.total_intersections,#(lf)    staging.refresh_duration/1000 as refresh_duration_sec#(lf)    from PROD_RAW.PROD_TEAM_SANDBOX.ADHOC_RUM_DATA_STAGING staging#(lf)    where staging.customer_id = '1309079513996591104'#(lf)),#(lf)#(lf)private_hub_no_rum_rows as#(lf)(#(lf)select#(lf)prod_tenant_info.tenant_id,#(lf)prod_tenant_info.tenant_nm,#(lf)prod_tenant_info.account_id,#(lf)adhoc_enabled.CONTRIBUTOR_ADHOC_ENABLED,#(lf)prod_tenant_info.data_cntr_cd as vena_hub,#(lf)concat(prod_tenant_info.data_cntr_cd,'.',prod_tenant_info.tenant_id) as dc_tenant_id,#(lf)null as user_id,#(lf)null as user_type,#(lf)null as action_datetime,#(lf)null as auth_type,#(lf)null as file_id,#(lf)null as office_version,#(lf)null as total_intersections,#(lf)null as refresh_duration_sec#(lf)from prod_tenant_info#(lf)left join adhoc_enabled #(lf)    on adhoc_enabled.vh_tenant_id = concat(prod_tenant_info.data_cntr_cd,'.',prod_tenant_info.tenant_id)#(lf)where prod_tenant_info.tenant_id in ('631326086198067200', '928495359901696000')#(lf))#(lf)#(lf)select *#(lf)from original_rows#(lf)#(lf)union all#(lf)#(lf)select *#(lf)from abbott_rum_rows#(lf)#(lf)union all#(lf)#(lf)select *#(lf)from private_hub_no_rum_rows", null, [EnableFolding=true]),
				    #"Duplicated Column" = Table.DuplicateColumn(Source, "ACTION_DATETIME", "ACTION_DATETIME - Copy"),
				    #"Renamed Columns" = Table.RenameColumns(#"Duplicated Column",{{"ACTION_DATETIME - Copy", "Date"}}),
				    #"Changed Type" = Table.TransformColumnTypes(#"Renamed Columns",{{"Date", type date}}),
				    #"Duplicated Column1" = Table.DuplicateColumn(#"Changed Type", "ACTION_DATETIME", "ACTION_DATETIME - Copy"),
				    #"Calculated End of Month" = Table.TransformColumns(#"Duplicated Column1",{{"ACTION_DATETIME - Copy", Date.EndOfMonth, type datetime}}),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Calculated End of Month",{{"ACTION_DATETIME - Copy", type date}}),
				    #"Renamed Columns1" = Table.RenameColumns(#"Changed Type1",{{"ACTION_DATETIME - Copy", "end of month"}})
				in
				    #"Renamed Columns1"

	annotation PBI_NavigationStepName = Navigation

