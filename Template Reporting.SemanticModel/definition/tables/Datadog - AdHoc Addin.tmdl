table 'Datadog - AdHoc Addin'
	lineageTag: 9634efdd-fb06-4405-ae70-760fadb73fb5

	measure 'FY26 MVP - Monthly Active Users (Trailing 90 Days)' = calculate(DISTINCTCOUNT('Datadog - AdHoc Addin'[USER_ID]), 'Datadog - AdHoc Addin'[Date] >= today()-90)/3
		formatString: #,0
		lineageTag: 9d1decb4-7a17-4fe5-847b-1f2738aa51d3

	measure 'FY26 MVP - EOM' =
			calculate(DISTINCTCOUNT('Datadog - AdHoc Addin'[USER_ID]), DATESBETWEEN('Datadog - AdHoc Addin'[Date],max('Datadog - AdHoc Addin'[Date])-90, max('Datadog - AdHoc Addin'[Date]))
			
			
			
			)
		formatString: #,0
		lineageTag: 2f0bd8bf-7f0f-4e32-b8f3-6261e1372cd2

	measure 'FY26 MVP - EOM date table' = calculate(DISTINCTCOUNT('Datadog - AdHoc Addin'[USER_ID]), 'Date Table'[Date] <= today(), DATESBETWEEN('Date Table'[Date],max('Date Table'[Date])-90, max('Date Table'[Date])))
		formatString: #,0
		lineageTag: 375f20b7-e86b-4074-9b09-de12f38e4783

	measure Measure = today()-90
		formatString: #,0
		lineageTag: 2ff5a52d-a5f7-43cd-9f8f-fa9eac8a4275

