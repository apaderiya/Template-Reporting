	partition 'Summary Template Addins Tenant Info' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_RAW"]}[Data], "with prod_tenant_list as #(lf)(#(lf)select distinct#(lf)tenant_id,#(lf)TENANT_NM, #(lf)eff_from_dt,#(lf)account_id,#(lf)data_cntr_cd#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm in ('PRODUCTION')#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf)),#(lf)#(lf)arr as #(lf)(#(lf)select#(lf)dc_tenant_id,#(lf)account_nm,#(lf)arr_usd#(lf)from PROD_HARMONIZED.PRODUCT.VW_ENBLD_PRODUCTION_TENANTS#(lf)),#(lf)#(lf)acc as #(lf)(#(lf)select #(lf)account_id,#(lf)became_customer_dt,#(lf)indstry_nm,#(lf)territory_sgmnt_nm,#(lf)renewal_dt#(lf)from PROD_HARMONIZED.SALES.VW_ACCOUNT_PROF#(lf)),#(lf)#(lf)cont as #(lf)#(lf)(#(lf)SELECT distinct#(lf)substr(tenant_dc,charindex('.', tenant_dc)+1,len(tenant_dc)) as tenant_id,#(lf)user_id#(lf)FROM PROD_HARMONIZED.PRODUCT.VW_USER_PROF#(lf)where crnt_rcrd_ind = 'Y'#(lf)--and actvtn_status_nm = 'ACTIVE'#(lf)and cntrbtr_access_ind = 'Y'#(lf)--and admin_access_ind = 'N'#(lf)and last_impersonation_login_dt is null #(lf)and ntfctn_email is null#(lf)order by user_id#(lf)),#(lf)#(lf)hydra as #(lf)(#(lf)select #(lf)    hydra.tenant_id,#(lf)--    tenant_nm,#(lf)    max(session_start_dts) as latest_desktop_ts#(lf)#(lf)from PROD_HARMONIZED.PRODUCT.HYDRA_UI_ACTIONS hydra#(lf)inner join cont on cont.tenant_id = hydra.tenant_id and cont.user_id = hydra.user_id#(lf)#(lf)where hydra.event_nm ilike '%simplerefresh%'   #(lf)and hydra.timing_ctgry_nm = 'DesktopAddin'#(lf)--and to_date(session_start_dts) < '2024-05-01'#(lf)group by hydra.tenant_id--,tenant_nm#(lf)),#(lf)#(lf)#(lf)v as #(lf)(#(lf)select #(lf)region,#(lf)customer_id as tenant_id,#(lf)--tenant_nm,#(lf)max(etl_load_date) as latest_365_ts#(lf)#(lf)from PROD_RAW.PROD_TEAM_SANDBOX.VENALYTICS_RUM_DATA_STAGING staging#(lf)--inner join prod_tenant_list on staging.customer_id = prod_tenant_list.tenant_id and staging.region = prod_tenant_list.data_cntr_cd#(lf)inner join cont on cont.tenant_id = staging.customer_id and staging.user_id =staging.user_id#(lf)where file_id is not null #(lf)and total_duration is not null#(lf)--and etl_load_date < '2024-05-01'#(lf)and is_initial_load = 'True'#(lf)group by region,customer_id--, tenant_nm#(lf)),#(lf)#(lf)v9 as#(lf)(#(lf)select #(lf)v9.sf_account_id,#(lf)predict_proba_1 as churn_probability #(lf)from PROD_PRESENTATION.CHURN_PREDICTION.VW_CHURN_PREDICTION_MONTHLY__MODEL_V9 v9#(lf)inner join #(lf)(#(lf)select #(lf)sf_account_id,#(lf)max(fiscal_month) as maxdate#(lf)from PROD_PRESENTATION.CHURN_PREDICTION.VW_CHURN_PREDICTION_MONTHLY__MODEL_V9#(lf)group by sf_account_id#(lf))maxdate#(lf)on v9.sf_account_id = maxdate.sf_account_id and v9.fiscal_month = maxdate.maxdate#(lf)),#(lf)#(lf)legacy_connector as #(lf)(#(lf)select #(lf)track.account_id,#(lf)sum(num_events) as total_events,#(lf)sum(num_minutes) as total_minutes,#(lf)max(_fivetran_synced) as latest_usage#(lf)from PROD_RAW.PENDO.TRACK_TYPE_EVENT track #(lf)where track_type_id = 'm6dr7UFzH5cEzVPeyHcm-dKK3_4'#(lf)group by #(lf)track.account_id#(lf))#(lf)#(lf)select #(lf)prod_tenant_list.tenant_id,#(lf)prod_tenant_list.tenant_nm,#(lf)prod_tenant_list.account_id,#(lf)account_nm,#(lf)arr_usd,#(lf)churn_probability,#(lf)eff_from_dt,#(lf)latest_desktop_ts,#(lf)latest_365_ts,#(lf)case #(lf)when latest_desktop_ts >= (current_date()-30) and latest_365_ts >= (current_date()-30) then 'Used Both Addins Recently'#(lf)when latest_desktop_ts >= (current_date()-30) and latest_365_ts is null then 'Used Desktop Addin Recently'#(lf)when latest_desktop_ts is null  and latest_365_ts >= (current_date()-30) then 'Used 365 Addin Recently'#(lf)end as which_addin,#(lf)case #(lf)when latest_desktop_ts >= (current_date()-365) and latest_365_ts >= (current_date()-365) then 'Refreshed Templates for Both Addins Past Year'#(lf)when latest_desktop_ts >= (current_date()-365) and latest_365_ts is null then 'Refreshed Templates for Desktop Addin Past Year'#(lf)when latest_desktop_ts is null  and latest_365_ts >= (current_date()-365) then 'Refreshed Templates for 365 Addin Past Year'#(lf)end as which_addin_LTM,#(lf)total_events as initializations_legacy_mac_connector,#(lf)latest_usage as most_recent_legacy_mac_connector_usage,#(lf)case #(lf)when latest_usage >= (current_date()-365) then 'Legacy Mac Connector Used LTM'#(lf)when latest_usage < (current_date()-365) then 'Legacy Mac Connector Used but Not Within LTM'#(lf)when latest_usage is null then 'Legacy Mac Connector Never Used'#(lf)else null end as legacy_mac_connector_usage_status#(lf)from prod_tenant_list#(lf)left join v on prod_tenant_list.tenant_id = v.tenant_id and prod_tenant_list.data_cntr_cd = v.region#(lf)left join v9 on prod_tenant_list.account_id = left(v9.sf_account_id,15)#(lf)left join legacy_connector on concat(data_cntr_cd,'.',prod_tenant_list.tenant_id) = legacy_connector.account_id#(lf)left join arr on arr.dc_tenant_id = concat(data_cntr_cd,'.',prod_tenant_list.tenant_id)#(lf)left join hydra on prod_tenant_list.tenant_id = hydra.tenant_id#(lf)--tough to deal with in relationships, exists in aws and azure#(lf)where prod_tenant_list.tenant_id <> '1497761032260681728'", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

