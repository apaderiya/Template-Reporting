	measure 'Chart - Adoption by Month' =
			
			VAR CurrentMonthStart = MIN( 'Date Table'[Date] )
			VAR CurrentMonthEnd   = MAX( 'Date Table'[Date] )
			
			VAR FileFirstActivation =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            VALUES( 'FCT Ops File Changes'[VH_FILE_ID] ),
			            "FirstWBDate",
			            CALCULATE(
			                MIN( 'FCT Ops File Changes'[CHANGE_DATE] ),
			                'FCT Ops File Changes'[NUMBER_OF_WRITEBACK_QUERIES] >= 1
			            )
			        ),
			        ALL( 'Date Table' )
			    )
			
			VAR FilesThisMonth =
			    FILTER(
			        FileFirstActivation,
			        NOT ISBLANK( [FirstWBDate] )
			            && [FirstWBDate] >= CurrentMonthStart
			            && [FirstWBDate] <= CurrentMonthEnd
			    )
			
			RETURN
			    COUNTROWS( FilesThisMonth )
		formatString: #,0
		displayFolder: Ops Table
		lineageTag: 93643524-b6a0-403e-bd34-04698f2ff281

