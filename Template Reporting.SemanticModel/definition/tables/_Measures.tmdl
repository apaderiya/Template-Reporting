	measure 'Customers - Active Last 30d' = ```
			
			VAR CutoffDate = TODAY() - 30
			VAR TenantsWithReads =
			    CALCULATETABLE(
			        VALUES( 'FCT Ops Table Actions'[VH_TENANT_ID] ),
			        'FCT Ops Table Actions'[ACTION_DATE] >= CutoffDate,
			        'FCT Ops Table Actions'[ACTION_TYPE] = "read_query"
			    )
			VAR TenantsWithWrites =
			    CALCULATETABLE(
			        VALUES( 'FCT Ops Table Actions'[VH_TENANT_ID] ),
			        'FCT Ops Table Actions'[ACTION_DATE] >= CutoffDate,
			        'FCT Ops Table Actions'[ACTION_TYPE] IN { "write"}
			    )
			RETURN
			    COUNTROWS( INTERSECT( TenantsWithReads, TenantsWithWrites ) )
			
