	partition 'Performance Report Tool Summary' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "WITH PROD_TENANT_INFO AS#(lf)(#(lf)select#(lf)tenant_id,#(lf)data_cntr_cd,#(lf)account_id,#(lf)tenant_nm#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm in ('PRODUCTION')#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf)),#(lf)#(lf)_365 as #(lf)(#(lf)select #(lf)event.account_id,#(lf)count(distinct visitor_id) as unique_365_users,#(lf)sum(num_events) as clicks_to_open_365_perf_tool#(lf)from PROD_RAW.PENDO.FEATURE_EVENT event #(lf)where feature_id = '3xSSDefFu94Q3S257ofYZ_KiLD8'#(lf)and to_date(_fivetran_synced) >= '2025-02-01'#(lf)group by #(lf)event.account_id#(lf)),#(lf)#(lf)desktop as #(lf)(#(lf)select #(lf)hydra.tenant_id,#(lf)count(distinct user_id) as unique_desktop_users,#(lf)count(distinct session_start_dts) as sessions_desktop_perf_tool#(lf)from PROD_HARMONIZED.PRODUCT.HYDRA_UI_ACTIONS hydra#(lf)where event_nm = 'PerformanceReportClicked'#(lf)and to_date(session_start_dts) >= '2025-02-01'#(lf)group by hydra.tenant_id#(lf))#(lf)#(lf)select #(lf)data_cntr_cd,#(lf)prod_tenant_info.tenant_id,#(lf)tenant_nm,#(lf)prod_tenant_info.account_id,#(lf)unique_desktop_users,#(lf)unique_365_users,#(lf)sessions_desktop_perf_tool,#(lf)clicks_to_open_365_perf_tool,#(lf)case #(lf)when sessions_desktop_perf_tool is not null and clicks_to_open_365_perf_tool is not null then 'used both addins'#(lf)when sessions_desktop_perf_tool is null and clicks_to_open_365_perf_tool is not null then 'used 365 addins'#(lf)when sessions_desktop_perf_tool is not null and clicks_to_open_365_perf_tool is null then 'used desktop addins'#(lf)when sessions_desktop_perf_tool is null and clicks_to_open_365_perf_tool is null then 'not used perf tool yet'#(lf)else null end as perf_tool_status#(lf)from prod_tenant_info #(lf)left join _365 on concat(prod_tenant_info.data_cntr_cd,'.',prod_tenant_info.tenant_id) = _365.account_id #(lf)left join desktop on desktop.tenant_id = prod_tenant_info.tenant_id", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

