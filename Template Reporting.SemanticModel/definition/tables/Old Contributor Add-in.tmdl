	partition 'Old Contributor Add-in' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_RAW"]}[Data], "WITH PROD_TENANT_INFO AS#(lf)(#(lf)select#(lf)tenant_id,#(lf)tenant_nm,#(lf)account_id,#(lf)data_cntr_cd,#(lf)SSO_ENBLD_IND#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm in ('PRODUCTION')#(lf)and organization_typ_nm = 'CUSTOMER'#(lf))#(lf)#(lf)select #(lf)track.account_id,#(lf)tenant_nm,#(lf)SSO_ENBLD_IND,#(lf)sum(num_events) as total_events,#(lf)sum(num_minutes) as total_minutes,#(lf)max(_fivetran_synced) as latest_usage#(lf)from PROD_RAW.PENDO.TRACK_TYPE_EVENT track #(lf)inner join prod_tenant_info on concat(prod_tenant_info.data_cntr_cd, '.', tenant_id) = track.account_id #(lf)where track_type_id = 'm6dr7UFzH5cEzVPeyHcm-dKK3_4'#(lf)group by #(lf)track.account_id,#(lf)tenant_nm,#(lf)SSO_ENBLD_IND", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

