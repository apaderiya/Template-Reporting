	partition 'User Detail' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "SELECT distinct#(lf)substr(tenant_dc,charindex('.', tenant_dc)+1,len(tenant_dc)) as tenant_id,#(lf)user_id,#(lf)case #(lf)when ntfctn_email is not null then 'Vena Employee User' else 'Customer' end as internal_user,#(lf)admin_access_ind,#(lf)ntfctn_email,#(lf)last_impersonation_login_dt,#(lf)case #(lf)    when (last_impersonation_login_dt is not null and admin_access_ind = 'Y' and ntfctn_email is null) then 'Y'#(lf)    end as consultant_login,#(lf)#(lf)case  #(lf)    when (admin_access_ind = 'Y') then 'Admin'#(lf)    when (admin_access_ind = 'N' and cntrbtr_access_ind = 'Y' and mdlr_access_ind = 'N' and mngr_access_ind = 'N') then 'Contributor'#(lf)    when (admin_access_ind = 'N' and (mngr_access_ind = 'Y' or mdlr_access_ind = 'Y')) then 'Modeler/Manager'#(lf)    else 'Other'#(lf)    end as permissions_category,#(lf)    #(lf)    #(lf)cntrbtr_access_ind,#(lf)mdlr_access_ind,#(lf)mngr_access_ind,#(lf)rprtr_access_ind,#(lf)viewer_access_ind#(lf)FROM PROD_HARMONIZED.PRODUCT.VW_USER_PROF#(lf)where crnt_rcrd_ind = 'Y'#(lf)and actvtn_status_nm = 'ACTIVE'#(lf)order by user_id", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

