	partition 'Desktop Add-in Modified and Saved' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "WITH PROD_TENANT_INFO AS#(lf)(#(lf)select#(lf)tenant_id,#(lf)tenant_nm,#(lf)data_cntr_cd#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf)and tenant_typ_nm in ('PRODUCTION','SANDBOX')#(lf))#(lf)#(lf)#(lf)Select #(lf)api.data_cntr_cd,#(lf)tenant_nm,#(lf)api.tenant_id,#(lf)user_id,#(lf)to_date(request_end_dts) as saved_modified_date,#(lf)#(lf)    sum(case when request_endpoint_nm ilike '%/api/models/{p}/values%' then 1 else 0 end) as contributor_modify_save,#(lf)    sum(case when request_endpoint_nm = '/api/files/{p}/data/' then 1 else 0 end) as manager_data_save#(lf)    #(lf)from PROD_HARMONIZED.PRODUCT.USER_API_ACTIVITY api #(lf)inner join prod_tenant_info on prod_tenant_info.tenant_id = api.tenant_id and prod_tenant_info.data_cntr_cd = api.data_cntr_cd#(lf)where to_date(request_end_dts) > '2023-02-01'#(lf)and (request_endpoint_nm ilike '%/api/models/{p}/values%' and request_method_cd = 'PATCH') or (request_endpoint_nm = '/api/files/{p}/data/' and REQUEST_METHOD_CD = 'POST')#(lf)and user_imprsntd_ind = 'N'#(lf)and vena_spprt_user_nm is null #(lf)and request_status_cd = '200'#(lf)#(lf)group by #(lf)api.data_cntr_cd,#(lf)tenant_nm,#(lf)api.tenant_id,#(lf)user_id,#(lf)to_date(request_end_dts)", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

