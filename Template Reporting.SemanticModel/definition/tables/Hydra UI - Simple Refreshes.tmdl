	partition 'Hydra UI - Simple Refreshes' = m
		mode: import
		queryGroup: 'Core Dataset'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "with prod_tenant_list as #(lf)(#(lf)select distinct#(lf)tenant_id,#(lf)TENANT_NM, #(lf)data_cntr_cd#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm in ('PRODUCTION', 'SANDBOX')#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf)),#(lf)#(lf)bit_version as #(lf)(#(lf)select distinct#(lf)tenant_id,#(lf)user_id,#(lf)session_id,#(lf)event_nm,#(lf)timing_vrbl_nm,#(lf)right(timing_val, 2) as bit_excel#(lf)from PROD_HARMONIZED.PRODUCT.HYDRA_UI_ACTIONS #(lf)where event_nm ilike '%ExcelVersion%'#(lf)),#(lf)#(lf)addin_version as#(lf)(#(lf)select distinct#(lf)tenant_id,#(lf)user_id,#(lf)session_id,#(lf)event_nm,#(lf)timing_vrbl_nm,#(lf)timing_val as addin_version#(lf)from PROD_HARMONIZED.PRODUCT.HYDRA_UI_ACTIONS #(lf)where event_nm ilike '%addinversion%'#(lf)),#(lf)#(lf)files as #(lf)(#(lf)select distinct#(lf)    tenant_id,#(lf)    user_id,#(lf)    rcrd_id,#(lf)    session_id,#(lf)    event_nm,#(lf)    timing_ctgry_nm,#(lf)    timing_vrbl_nm,#(lf)    timing_val as file_id,#(lf)    session_start_dts as hydra_timestamp,#(lf)    src_system_cd#(lf)#(lf)from PROD_HARMONIZED.PRODUCT.HYDRA_UI_ACTIONS #(lf)#(lf)where event_nm ilike '%fileid%'#(lf)and timing_ctgry_nm = 'DesktopAddin'#(lf)),#(lf)#(lf)tstudio as #(lf)(#(lf)select distinct#(lf)data_center,#(lf)A.tenant_id,#(lf)file_id,#(lf)solution_package_name,#(lf)solution_package_template_name,#(lf)solution_package_template_version,#(lf)etl_load_date#(lf)from PROD_RAW.MT_SERVER.MTSERVER_TEMPLATE_METRICS_STAGING A#(lf)--where solution_package_name ilike '%studio%'#(lf)where solution_package_template_name ilike 'template studio%'#(lf)and to_date(etl_load_date) >= '2025-02-01'#(lf)and solution_package_template_name <> 'Template Studio Report'#(lf)),#(lf)#(lf)pcs as #(lf)(#(lf)select distinct#(lf)data_center,#(lf)metrics.tenant_id,#(lf)file_id,#(lf)solution_package_name,#(lf)solution_package_template_name,#(lf)solution_package_template_version#(lf)from PROD_RAW.MT_SERVER.MTSERVER_TEMPLATE_METRICS_STAGING metrics #(lf)where solution_package_name <> ''#(lf)and solution_package_template_name <> ''#(lf)and solution_package_template_version ilike '%.%'#(lf)and replace(solution_package_template_version, '.', '') >= 100#(lf))#(lf)#(lf)#(lf)select distinct#(lf)    hydra.tenant_id,#(lf)    tenant_nm,#(lf)    --concat(tenant_nm,' - ',hydra.timing_vrbl_nm) as tenant_template_name,#(lf)    hydra.user_id,#(lf)    files.file_id,#(lf)    hydra.timing_vrbl_nm,#(lf)    hydra.session_start_dts,#(lf)    bit_excel,#(lf)    addin_version,#(lf)    tstudio.solution_package_template_name as tstudio_template,#(lf)    pcs.solution_package_template_name as pcs_template,#(lf)    pcs.solution_package_template_version as pcs_package_version,#(lf)    cast(hydra.timing_val as float) as timing_val,#(lf)    to_date(hydra.session_start_dts) as date_of_refresh,#(lf)    month(hydra.session_start_dts) as month_of_refresh,#(lf)    year(hydra.session_start_dts) as year_of_refresh,#(lf)    round(cume_dist() OVER (partition by year_of_refresh, month_of_refresh order by cast(hydra.timing_val as float)),2) as percentile_figure#(lf)#(lf)from PROD_HARMONIZED.PRODUCT.HYDRA_UI_ACTIONS hydra#(lf)inner join prod_tenant_list on hydra.tenant_id = prod_tenant_list.tenant_id #(lf)left join bit_version on bit_version.tenant_id = hydra.tenant_id and bit_version.user_id = hydra.user_id and bit_version.session_id = hydra.session_id #(lf)left join addin_version on addin_version.tenant_id = hydra.tenant_id and addin_version.user_id = hydra.user_id and addin_version.session_id = hydra.session_id #(lf)left join files on files.tenant_id = hydra.tenant_id and files.user_id = hydra.user_id and files.session_id = hydra.session_id and files.timing_vrbl_nm = hydra.timing_vrbl_nm #(lf)left join tstudio on tstudio.file_id = files.file_id and tstudio.tenant_id = hydra.tenant_id#(lf)left join pcs on pcs.tenant_id = hydra.tenant_id and pcs.file_id = files.file_id #(lf)where hydra.event_nm ilike '%simplerefresh%'   #(lf)and hydra.timing_ctgry_nm = 'DesktopAddin'#(lf)and to_date(session_start_dts) >= (current_date()-365)", null, [EnableFolding=true]),
				    #"Merged Columns" = Table.CombineColumns(Table.TransformColumnTypes(Source, {{"YEAR_OF_REFRESH", type text}, {"MONTH_OF_REFRESH", type text}}, "en-CA"),{"YEAR_OF_REFRESH", "MONTH_OF_REFRESH"},Combiner.CombineTextByDelimiter(" ", QuoteStyle.None),"Year And Month.1"),
				    #"Changed Type" = Table.TransformColumnTypes(#"Merged Columns",{{"Year And Month.1", type date}}),
				    #"Renamed Columns" = Table.RenameColumns(#"Changed Type",{{"Year And Month.1", "Year And Month"}}),
				    #"Duplicated Column" = Table.DuplicateColumn(#"Renamed Columns", "Year And Month", "Year And Month - Copy"),
