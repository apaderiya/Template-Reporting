				    #"Calculated End of Week" = Table.TransformColumns(#"Renamed Columns1",{{"End of Week", Date.EndOfWeek, type date}}),
				    #"Renamed Columns2" = Table.RenameColumns(#"Calculated End of Week",{{"End of Week", "Start of Week"}}),
				    #"Calculated Start of Week" = Table.TransformColumns(#"Renamed Columns2",{{"Start of Week", Date.StartOfWeek, type date}}),
				    #"Merged Queries" = Table.NestedJoin(#"Calculated Start of Week", {"TENANT_ID", "FILE_ID"}, #"Named ranges by template", {"TENANT_ID", "FILE_ID"}, "Named ranges by template", JoinKind.LeftOuter),
				    #"Expanded Named ranges by template" = Table.ExpandTableColumn(#"Merged Queries", "Named ranges by template", {"NUMBE_OF_NAMED_RANGES"}, {"Named ranges by template.NUMBE_OF_NAMED_RANGES"}),
				    #"Rounded Up" = Table.TransformColumns(#"Expanded Named ranges by template",{{"Named ranges by template.NUMBE_OF_NAMED_RANGES", Number.RoundUp, Int64.Type}}),
				    #"Renamed Columns3" = Table.RenameColumns(#"Rounded Up",{{"Named ranges by template.NUMBE_OF_NAMED_RANGES", "# of Named Ranges"}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Renamed Columns3",{"SESSION_START_DTS"})
				in
				    #"Removed Columns"

	annotation PBI_ResultType = Table

