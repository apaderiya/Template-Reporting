	partition VW_DIM_TEMPLATE_METRICS = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH",[Implementation="2.0"]){[Name="PROD_HARMONIZED"]}[Data], "WITH PROD_TENANT_INFO AS#(lf)(#(lf)select#(lf)tenant_id,#(lf)tenant_nm,#(lf)tenant_typ_nm,#(lf)tenant_enbld_status_nm,#(lf)organization_typ_nm,#(lf)account_id,#(lf)data_cntr_cd#(lf)from PROD_HARMONIZED.PRODUCT.tenant_prof#(lf)where CRNT_RCRD_IND = 'Y'#(lf)--and tenant_typ_nm in ('PRODUCTION')#(lf)--and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf)), #(lf)#(lf)latest_etl as (#(lf)    select#(lf)    data_center,#(lf)    tenant_id,#(lf)    file_id,#(lf)    etl_load_date,#(lf)    number_of_operational_choose_mappings,#(lf)    number_of_writeback_queries#(lf)    from PROD_RAW.MT_SERVER.MTSERVER_TEMPLATE_METRICS_STAGING#(lf)    where number_of_operational_choose_mappings > 0#(lf)       or number_of_writeback_queries > 0#(lf)    qualify row_number() over (#(lf)        partition by data_center, tenant_id, file_id#(lf)        order by etl_load_date desc, content_id desc#(lf)        ) = 1#(lf)    #(lf))#(lf)#(lf)select#(lf)    data_center,#(lf)    latest_etl.tenant_id,#(lf)    tenant_nm,#(lf)    tenant_typ_nm,#(lf)    organization_typ_nm,#(lf)    tenant_enbld_status_nm,#(lf)    file_id,#(lf)    latest_etl.etl_load_date,#(lf)    number_of_operational_choose_mappings,#(lf)    number_of_writeback_queries#(lf)from latest_etl#(lf)left join prod_tenant_info on #(lf)prod_tenant_info.data_cntr_cd = right(latest_etl.data_center,3)#(lf)and prod_tenant_info.tenant_id = latest_etl.tenant_id #(lf)order by etl_load_date DESC", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

