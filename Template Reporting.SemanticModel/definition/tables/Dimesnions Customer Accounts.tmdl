	partition 'Dimesnions Customer Accounts' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "with acc as #(lf)(#(lf)select #(lf)account_id,#(lf)became_customer_dt,#(lf)indstry_nm,#(lf)territory_sgmnt_nm,#(lf)renewal_dt,#(lf)zoom_indstry_nm,#(lf)zoom_prmry_indstry_nm,#(lf)zoom_prmry_sub_indstry_nm,#(lf)zoom_employee_count,#(lf)zoom_revenue,#(lf)powerbi_embedded_ind,#(lf)churn_rsk_ind,#(lf)website_url#(lf)from PROD_HARMONIZED.SALES.VW_ACCOUNT_PROF#(lf)where crnt_rcrd_ind = 'Y'#(lf))#(lf)#(lf)select distinct#(lf)tenants.account_id as account_id_long,#(lf)left(tenants.account_id,15) as account_id_short,#(lf)account_nm,#(lf)arr_usd,#(lf)admin_license_sold,#(lf)business_license_sold,#(lf)any_combination_license_sold,#(lf)view_only_license_sold,#(lf)total_license_sold,#(lf)became_customer_dt,#(lf)indstry_nm,#(lf)territory_sgmnt_nm,#(lf)renewal_dt,#(lf)zoom_indstry_nm,#(lf)zoom_prmry_indstry_nm,#(lf)zoom_prmry_sub_indstry_nm,#(lf)zoom_employee_count,#(lf)zoom_revenue,#(lf)powerbi_embedded_ind,#(lf)churn_rsk_ind,#(lf)website_url#(lf)from PROD_HARMONIZED.PRODUCT.VW_ENBLD_PRODUCTION_TENANTS tenants #(lf)left join acc on tenants.account_id = acc.account_id#(lf)where tenants.account_typ_nm = 'Customer'#(lf)and tenant_typ_nm = 'PRODUCTION'#(lf)and tenant_enbld_status_nm = 'ENABLED'", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

