	partition 'Tempalte Sizes Global' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "with prod_tenant_list as #(lf)(#(lf)select#(lf)data_cntr_cd,#(lf)tenant_id,#(lf)tenant_nm#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm = 'PRODUCTION'#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf))#(lf)#(lf)#(lf)select #(lf)files.data_cntr_cd,#(lf)files.tenant_id,#(lf)files.glbl_file_id,#(lf)files.file_size_bytes/1000000 as file_size_mb,#(lf)files.file_extn_nm#(lf)from PROD_HARMONIZED.PRODUCT.GLBL_FILE_DTL files#(lf)inner join prod_tenant_list on prod_tenant_list.tenant_id = files.tenant_id and prod_tenant_list.data_cntr_cd = files.data_cntr_cd", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

