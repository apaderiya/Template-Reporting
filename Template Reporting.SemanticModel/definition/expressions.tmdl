		let
		    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "with prod_tenant_list as #(lf)(#(lf)select distinct#(lf)tenant_id,#(lf)TENANT_NM#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm in ('PRODUCTION', 'SANDBOX')#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf))#(lf)#(lf)select distinct#(lf)    hydra.tenant_id,#(lf)    tenant_nm,#(lf)    concat(tenant_nm,' - ',hydra.timing_vrbl_nm) as tenant_template_name,#(lf)    hydra.user_id,#(lf)    hydra.session_id,#(lf)    hydra.timing_vrbl_nm,#(lf)    hydra.session_start_dts,#(lf)    cast(hydra.timing_val as float) as timing_val,#(lf)    to_date(hydra.session_start_dts) as date_of_refresh,#(lf)    month(hydra.session_start_dts) as month_of_refresh,#(lf)    year(hydra.session_start_dts) as year_of_refresh,#(lf)    round(cume_dist() OVER (partition by year_of_refresh, month_of_refresh order by cast(hydra.timing_val as float)),2) as percentile_figure,#(lf)    Case#(lf)        when hydra.timing_vrbl_nm ilike '%xlsb%' then 'XLSB'#(lf)        when hydra.timing_vrbl_nm ilike '%xlsm%' then 'XLSM'#(lf)        when hydra.timing_vrbl_nm ilike '%xlsx%' then 'XLSX'#(lf)        when hydra.timing_vrbl_nm ilike '%xls%' then 'XLS'#(lf)        when hydra.timing_vrbl_nm ilike '%csv%' then 'CSV'#(lf)        when hydra.timing_vrbl_nm ilike '%txt%' then 'TXT'#(lf)        else 'Other' end as File_Type#(lf)#(lf)from PROD_HARMONIZED.PRODUCT.HYDRA_UI_ACTIONS hydra#(lf)inner join prod_tenant_list on hydra.tenant_id = prod_tenant_list.tenant_id#(lf)#(lf)where event_nm ilike '%simplerefresh%'   #(lf)and timing_ctgry_nm = 'DesktopAddin'", null, [EnableFolding=true]),
		    #"Merged Columns" = Table.CombineColumns(Table.TransformColumnTypes(Source, {{"YEAR_OF_REFRESH", type text}, {"MONTH_OF_REFRESH", type text}}, "en-CA"),{"YEAR_OF_REFRESH", "MONTH_OF_REFRESH"},Combiner.CombineTextByDelimiter(" ", QuoteStyle.None),"Year And Month.1"),
		    #"Changed Type" = Table.TransformColumnTypes(#"Merged Columns",{{"Year And Month.1", type date}}),
