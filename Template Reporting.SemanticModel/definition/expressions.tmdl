		    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "with prod_tenant_list as #(lf)(#(lf)select#(lf)tenant_id#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm in ('PRODUCTION', 'SANDBOX')#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf))#(lf)#(lf)#(lf)select #(lf)api.tenant_id,#(lf)data_cntr_cd,#(lf)user_id,#(lf)request_start_dts,#(lf)request_end_dts,#(lf)request_endpoint_nm,#(lf)case #(lf)when request_endpoint_nm = '/api/models/{p}/values/2D/' and request_method_cd = 'POST' then 'get the Slice data for static mappings in a block'#(lf)when request_endpoint_nm = '/api/models/{p}/values/2D/dynamic/' and request_method_cd = 'POST' then 'get the Slice data for dynamic mappings in a block'#(lf)when request_endpoint_nm = '/api/models/{p}/lids/2D/' and request_method_cd = 'POST' then 'get LIDS for a Slice'#(lf)when request_endpoint_nm in ('/fsm/v2', '/api/properties/ADDIN', '/addinVersion ','/api/users/current') or (request_endpoint_nm ilike '/api/currentCustomer%' or request_endpoint_nm ilike '/api/processes/%' or request_endpoint_nm ilike '/api/models/%') and request_method_cd = 'GET' then 'invoked during template load'#(lf)when request_endpoint_nm in ('/api/models/{p}/etl/staging/database/','/api/models/{p}/etl/staging/tables/') and request_method_cd = 'GET' then 'Get LIDS for a slice'#(lf)when request_endpoint_nm in ('/api/models/{p}/etl/query/staging/') and request_method_cd = 'POST' then 'Get LIDS for a slice'#(lf)else 'n/a' end as endpoint_action,#(lf)request_url,#(lf)request_method_cd,#(lf)request_status_cd#(lf)#(lf)from PROD_HARMONIZED.PRODUCT.USER_API_ACTIVITY API#(lf)inner join prod_tenant_list on prod_tenant_list.tenant_id = API.TENANT_ID#(lf)where #(lf)#(lf)user_agent = 'Mozilla/5.0 (compatible; MSIE 10.0; Windows NT 6.1; Trident/6.0)'#(lf)and request_endpoint_nm not in #(lf)(#(lf)'/api/models/{p}/values/intersections/calcs/',#(lf)'/api/models/{p}/labels/',#(lf)'/api/models/{p}/intersections/revisions/',#(lf)'/api/models/{p}/intersections/deletedLids/',#(lf)'/api/models/{p}/intersections/',#(lf)'/api/models/{p}/fullDataAccess/',#(lf)'/api/models/{p}/dataPermission/members/',#(lf)'/api/models/mdx/'#(lf))#(lf)and #(lf)(request_endpoint_nm in ('/fsm/v2', '/api/properties/ADDIN', '/addinVersion ','/api/users/current')#(lf)or request_endpoint_nm ilike '/api/currentCustomer%'#(lf)or request_endpoint_nm ilike '/api/processes/%'#(lf)or request_endpoint_nm ilike'/api/models/{p}/etl/query/staging/'#(lf)or request_endpoint_nm ilike'/api/models/{p}/etl/staging/tables/'#(lf)or request_endpoint_nm ilike'/api/models/{p}/etl/staging/database/'#(lf)or request_endpoint_nm ilike '/api/models/%')#(lf)#(lf)and to_date(request_end_dts) > (current_date()-30)", null, [EnableFolding=true]),
		    #"Added Custom" = Table.AddColumn(Source, "REQUEST_TIME_SPENT", each [REQUEST_END_DTS]-[REQUEST_START_DTS]),
		    #"Reordered Columns" = Table.ReorderColumns(#"Added Custom",{"TENANT_ID", "DATA_CNTR_CD", "USER_ID", "REQUEST_START_DTS", "REQUEST_END_DTS", "REQUEST_TIME_SPENT", "REQUEST_ENDPOINT_NM", "ENDPOINT_ACTION", "REQUEST_URL", "REQUEST_METHOD_CD", "REQUEST_STATUS_CD"}),
		    #"Extracted Seconds" = Table.TransformColumns(#"Reordered Columns",{{"REQUEST_TIME_SPENT", Duration.Seconds, type number}})
		in
		    #"Extracted Seconds"
