expression 'Export Tool API Activity' =
		let
		    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","product_power_user_read_wh"){[Name="PROD_HARMONIZED"]}[Data], "WITH PROD_TENANT_INFO AS#(lf)(#(lf)select#(lf)tenant_id#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm = 'PRODUCTION'#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf)),#(lf)#(lf)#(lf)user_list as#(lf)(#(lf)SELECT distinct#(lf)substr(tenant_dc,charindex('.', tenant_dc)+1,len(tenant_dc)) as tenant_id,#(lf)user_id,#(lf)case #(lf)when ntfctn_email is not null then 'Vena Employee User' else 'Customer' end as internal_user#(lf)FROM PROD_HARMONIZED.PRODUCT.VW_USER_PROF#(lf)where crnt_rcrd_ind = 'Y'#(lf)and actvtn_status_nm = 'ACTIVE'#(lf)order by user_id#(lf))#(lf)#(lf)#(lf)#(lf)SELECT #(lf)    A.TENANT_ID,#(lf)    A.USER_ID,#(lf)    internal_user,#(lf)    CASE #(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%STARTWITHFILE%' THEN 'START WITH FILE'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%STARTWITHDATA%' THEN 'START WITH DATA'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%CANCEL%' THEN 'CANCEL JOB'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%STATUS%' THEN 'GET JOB STATUS'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%/API/PUBLIC/V1/ETL/TEMPLATES%' THEN 'LIST/GET TEMPLATE(S)'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%/API/PUBLIC/V1/ETL/JOBS%' THEN 'GET JOB'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/attributes/%' THEN 'Export Attributes'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/hierarchies%' THEN 'Export Hierarchies'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/lids2%' THEN 'Export Line Item Details'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/staging%' THEN 'Export Staging'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/intersections2%' THEN 'Export Values'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/export/file%' THEN 'Export to File' #(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/upload%' THEN 'Export to Staging Table'#(lf)    ELSE NULL END AS ENDPOINT_ACTION, #(lf)    REQUEST_SIZE_B#(lf)#(lf)#(lf)FROM PROD_HARMONIZED.PRODUCT.USER_API_ACTIVITY A#(lf)INNER JOIN PROD_TENANT_INFO C ON A.TENANT_ID = C.TENANT_ID#(lf)LEFT JOIN user_list on A.TENANT_ID = USER_LIST.tenant_id and A.USER_ID = USER_LIST.USER_ID #(lf)#(lf)WHERE #(lf)#(lf)(#(lf) A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/attributes/%'#(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/hierarchies%' #(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/lids2%'#(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/staging%'#(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/intersections2%'#(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/export/file%' #(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/upload%' #(lf))#(lf)#(lf)and to_date(request_end_dts) > (current_date()-30)#(lf)ORDER BY A.TENANT_ID, A.DATA_CNTR_CD", null, [EnableFolding=true])
		in
		    Source
	lineageTag: 01e00289-221f-4687-a246-18170a789717
	queryGroup: 'Core Dataset'

