		    #"Expanded Hydra File IDs" = Table.ExpandTableColumn(#"Merged Queries", "Hydra File IDs", {"FILE_ID"}, {"Hydra File IDs.FILE_ID"}),
		    #"Renamed Columns1" = Table.RenameColumns(#"Expanded Hydra File IDs",{{"Hydra File IDs.FILE_ID", "FILE_ID"}}),
		    #"Merged Queries1" = Table.NestedJoin(#"Renamed Columns1", {"SESSION_ID", "TIMING_VRBL_NM"}, #"Hydra Content IDs", {"SESSION_ID", "TIMING_VRBL_NM"}, "Hydra Content IDs", JoinKind.LeftOuter),
		    #"Expanded Hydra Content IDs" = Table.ExpandTableColumn(#"Merged Queries1", "Hydra Content IDs", {"TIMING_VAL"}, {"Hydra Content IDs.TIMING_VAL"}),
		    #"Renamed Columns2" = Table.RenameColumns(#"Expanded Hydra Content IDs",{{"Hydra Content IDs.TIMING_VAL", "CONTENT_ID"}}),
		    #"Inserted Merged Column" = Table.AddColumn(#"Renamed Columns2", "TEMPLATE_GALAXY_ID", each Text.Combine({[TENANT_ID], [FILE_ID], [CONTENT_ID]}, "."), type text),
		    #"Filtered Rows" = Table.SelectRows(#"Inserted Merged Column", each Text.Contains([TEMPLATE_GALAXY_ID], "."))
		in
