TE, #(lf)GO_LIVE_DATE,#(lf)PROJECT_KICKOFF_DATE,#(lf)PROJECT_MANAGER_NAME,#(lf)project_budgeted_hours,#(lf)CUSTOMER_STATUS as client_status, #(lf)project_status, #(lf)project_phase,#(lf)V365_IMPLEMENTATION_IND,#(lf)srvcs_dlvrd_nms,#(lf)cohort_nm,#(lf)stories.stry_id,#(lf)stories.stry_title,#(lf)stories.stry_typ,#(lf)stories.stry_description,#(lf)stories.start_dt,#(lf)stories.due_dt,#(lf)year(dt_performed) as year, #(lf)weekofyear(DT_PERFORMED) as week, #(lf)sum(TIME_BOOKED_MINS)/60 as impl_hours  #(lf)#(lf)from ""PROD_PRESENTATION"".""PROFESSIONAL_SERVICES"".""VW_MAVENLINK_PROJECT_DETAILS"" projects#(lf)    #(lf)    left join ""PROD_PRESENTATION"".""PROFESSIONAL_SERVICES"".""VW_SF_ID_TO_VENA_ID_LOOKUP"" lookup on lookup.vena_id = projects.vena_id#(lf)    left join ""PROD_HARMONIZED"".""SALES"".""VW_ACCOUNT_PROF"" accounts on left(lookup.account_id, 15) = left(accounts.account_id, 15)#(lf)    left join ""PROD_PRESENTATION"".""PROFESSIONAL_SERVICES"".""VW_PROJECT_STORY_INFO"" stories on stories.VENA_PROJECT_CD = projects.PROJECT_CODE#(lf)#(lf)where ((accounts.CRNT_RCRD_IND is null) or accounts.CRNT_RCRD_IND = 'Y')#(lf)#(lf)group by #(lf)accounts.account_id,#(lf)accounts.account_nm, #(lf)accounts.ACCOUNT_TYP_NM,#(lf)projects.vena_id,#(lf)projects.project_code,#(lf)accounts.TERRITORY_SGMNT_NM, #(lf)projects.task_name, #(lf)projects.task_name, #(lf)SOW_SIGN_DATE, #(lf)GO_LIVE_DATE, #(lf)PROJECT_MANAGER_NAME,#(lf)PROJECT_KICKOFF_DATE,#(lf)project_budgeted_hours,#(lf)client_status, #(lf)project_status, #(lf)project_phase,#(lf)V365_IMPLEMENTATION_IND,#(lf)srvcs_dlvrd_nms,#(lf)cohort_nm,#(lf)stories.stry_id,#(lf)stories.stry_title,#(lf)stories.stry_typ,#(lf)stories.stry_description,#(lf)stories.start_dt,#(lf)stories.due_dt,#(lf)year(dt_performed), #(lf)weekofyear(DT_PERFORMED)#(lf)#(lf)order by accounts.account_nm, year, week#(lf)#(lf))#(lf)#(lf)SELECT #(lf)    Prod_tenant_info.tenant_ID,#(lf)    prod_tenant_info.tenant_nm,#(lf)    PS_HOURS.project_code,#(lf)    PS_HOURS.ACCOUNT_NM, #(lf)    PS_HOURS.ACCOUNT_TYP_NM,  #(lf)    PS_HOURS.TERRITORY_SGMNT_NM,#(lf)    ARR.TOTAL_ARR,#(lf)    PS_HOURS.TASK_NAME,#(lf)    SETTINGS.ENABLE_VENA_365_CONNECT_BY_DEFAULT,#(lf)    PS_HOURS.V365_IMPLEMENTATION_IND,#(lf)--    PS_HOURS.Client_STATUS,#(lf)    PS_HOURS.SOW_SIGN_DATE, #(lf)    PS_HOURS.GO_LIVE_DATE, #(lf)    PROJECT_KICKOFF_DATE,#(lf)    PS_HOURS.PROJECT_MANAGER_NAME,#(lf)    PS_HOURS.PROJECT_BUDGETED_HOURS,#(lf)    PS_HOURS.client_STATUS as customer_status, #(lf)    PS_HOURS.PROJECT_STATUS, #(lf)    PS_HOURS.PROJECT_PHASE,#(lf)    srvcs_dlvrd_nms,#(lf)    cohort_nm,#(lf)--    PS_HOURS.stry_id,#(lf)    PS_HOURS.stry_title,#(lf)--    PS_HOURS.stry_typ,#(lf)    PS_hours.start_dt,#(lf)    PS_hours.due_dt,#(lf)    PS_HOURS.stry_description,#(lf)    PS_HOURS.YEAR, #(lf)    PS_HOURS.WEEK, #(lf)    PS_HOURS.impl_hours#(lf)#(lf)#(lf)FROM PS_HOURS#(lf)INNER JOIN prod_tenant_info on PS_HOURS.account_id = prod_tenant_info.account_id#(lf)INNER JOIN settings on settings.TENANT_ID = prod_tenant_info.TENANT_ID#(lf)LEFT JOIN ARR on PS_HOURS.ACCOUNT_ID = ARR.ACCOUNT_ID#(lf)order by tenant_id, PROJECT_CODE, STRY_ID", null, [EnableFolding=true]),
