expression 'Hydra UI - C#' =
		let
		    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_wh"){[Name="PROD_HARMONIZED"]}[Data], "with prod_tenant_list as #(lf)(#(lf)select distinct#(lf)tenant_id#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm = 'PRODUCTION'#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf))#(lf)#(lf)select #(lf)    hydra.tenant_id,#(lf)--    hydra.user_id,#(lf)--    rcrd_id,#(lf)--    session_id,#(lf)    event_nm,#(lf)    timing_ctgry_nm,#(lf)    timing_vrbl_nm,#(lf)    Case#(lf)    when timing_vrbl_nm ilike '%xlsb%' then 'XLSB'#(lf)    when timing_vrbl_nm ilike '%xlsm%' then 'XLSM'#(lf)    when timing_vrbl_nm ilike '%xlsx%' then 'XLSX'#(lf)    when timing_vrbl_nm ilike '%xls%' then 'XLS'#(lf)    when timing_vrbl_nm ilike '%csv%' then 'CSV'#(lf)    when timing_vrbl_nm ilike '%txt%' then 'TXT'#(lf)    else 'Other' end as File_Type,#(lf)    to_date(session_start_dts) as date_of_refresh,#(lf)    month(session_start_dts) as month_of_refresh,#(lf)    year(session_start_dts) as year_of_refresh,#(lf)    round(cume_dist() OVER (partition by year_of_refresh, month_of_refresh order by cast(timing_val as float)),2) as percentile_figure,#(lf)    cast(timing_val as float) as timing_val#(lf)    #(lf)--    src_system_cd#(lf)#(lf)from PROD_HARMONIZED.PRODUCT.HYDRA_UI_ACTIONS hydra#(lf)inner join prod_tenant_list on hydra.tenant_id = prod_tenant_list.tenant_id#(lf)#(lf)where #(lf)(#(lf)event_nm ilike '%simplerefresh%'   -- Saas Technology MVP value, evaluated by percentiles#(lf)OR event_nm ilike '%OpenToLoadTime%' -- evaluated by percentiles#(lf)OR event_nm ilike '%LoadToGetDataTime%' -- evaluated by percentiles#(lf)OR event_nm ilike '%WorksheetUnprotectCount%' -- not a time metric#(lf)OR event_nm ilike '%WorksheetUnprotectTime%' -- evaluated by percentiles#(lf))#(lf)#(lf)and timing_ctgry_nm = 'DesktopAddin'", null, [EnableFolding=true]),
		    #"Changed Type" = Table.TransformColumnTypes(Source,{{"TIMING_VAL", type number}})
		in
		    #"Changed Type"
	lineageTag: db1c044e-fe59-45a5-909d-a5724e32debf
	queryGroup: 'Core Dataset'

