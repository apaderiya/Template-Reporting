		    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "WITH PROD_TENANT_INFO AS#(lf)(#(lf)select#(lf)tenant_id#(lf)from PROD_HARMONIZED.PRODUCT.TENANT_PROF#(lf)where CRNT_RCRD_IND = 'Y'#(lf)and tenant_typ_nm in ('PRODUCTION', 'SANDBOX')#(lf)and organization_typ_nm = 'CUSTOMER'#(lf)and tenant_enbld_status_nm = 'ENABLED'#(lf)),#(lf)#(lf)#(lf)user_list as#(lf)(#(lf)SELECT #(lf)right(tenant_dc,19) as tenant_id,#(lf)user_id,#(lf)case #(lf)when ntfctn_email is not null then 'Vena Employee User' else 'Customer' end as internal_user#(lf)FROM PROD_HARMONIZED.PRODUCT.VW_USER_PROF#(lf)where crnt_rcrd_ind = 'Y'#(lf)and actvtn_status_nm = 'ACTIVE'#(lf)),#(lf)#(lf)#(lf)API_CALL_COUNT AS#(lf)(#(lf)    SELECT #(lf)        A.TENANT_ID,#(lf)        A.DATA_CNTR_CD,#(lf)        MIN(REQUEST_START_DTS) AS EARLIEST_REQUEST_DTS,#(lf)        MAX(REQUEST_START_DTS) AS LATEST_REQUEST_DTS, #(lf)        COUNT(*) AS API_REQUEST_COUNT_TOTAL#(lf)   #(lf)    FROM PROD_HARMONIZED.PRODUCT.USER_API_ACTIVITY A#(lf)    INNER JOIN PROD_TENANT_INFO B#(lf)    ON A.TENANT_ID = B.TENANT_ID#(lf)    #(lf)    WHERE REQUEST_ENDPOINT_NM ILIKE '%/API/PUBLIC/V1%'#(lf)    AND VENA_SPPRT_USER_NM IS NULL #(lf)    GROUP BY 1,2#(lf)    ORDER BY TENANT_ID, DATA_CNTR_CD#(lf))#(lf)#(lf)#(lf)SELECT #(lf)    A.TENANT_ID,#(lf)    A.USER_ID,#(lf)    internal_user,#(lf)    to_date(REQUEST_END_DTS) as request_end_date,#(lf)    API_REQUEST_COUNT_TOTAL,#(lf)    CASE #(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%STARTWITHFILE%' THEN 'START WITH FILE'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%STARTWITHDATA%' THEN 'START WITH DATA'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%CANCEL%' THEN 'CANCEL JOB'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%STATUS%' THEN 'GET JOB STATUS'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%/API/PUBLIC/V1/ETL/TEMPLATES%' THEN 'LIST/GET TEMPLATE(S)'#(lf)    WHEN REQUEST_ENDPOINT_NM ILIKE '%/API/PUBLIC/V1/ETL/JOBS%' THEN 'GET JOB'#(lf)    ELSE NULL END AS ENDPOINT_ACTION, #(lf)    REQUEST_ENDPOINT_NM,#(lf)    REQUEST_SIZE_B#(lf)#(lf)FROM PROD_HARMONIZED.PRODUCT.USER_API_ACTIVITY A#(lf)INNER JOIN PROD_TENANT_INFO C ON A.TENANT_ID = C.TENANT_ID#(lf)LEFT JOIN API_CALL_COUNT B ON A.TENANT_ID = B.TENANT_ID#(lf)LEFT JOIN USER_LIST ON A.USER_ID = USER_LIST.USER_ID#(lf)#(lf)WHERE A.REQUEST_ENDPOINT_NM ILIKE '%/API/PUBLIC/V1%'#(lf)ORDER BY A.TENANT_ID, A.DATA_CNTR_CD", null, [EnableFolding=true]),
		    #"Renamed Columns" = Table.RenameColumns(Source,{{"ENDPOINT_ACTION", "Endpoint Action"}, {"REQUEST_END_DATE", "Request End Date"}, {"REQUEST_ENDPOINT_NM", "Request Endpoint Name"}, {"REQUEST_SIZE_B", "Request Size"}, {"TENANT_ID", "Tenant ID"}, {"API_REQUEST_COUNT_TOTAL", "Total API Request Count"}})
		in
		    #"Renamed Columns"
