)concat(customer_id,'.',file_id) as tenant_file_id,#(lf)to_date(max(etl_load_date)) as latest_refresh_date,#(lf)'365' as addin_type#(lf)from PROD_RAW.PROD_TEAM_SANDBOX.VENALYTICS_RUM_DATA_STAGING staging#(lf)inner join prod_tenant_list on staging.customer_id = prod_tenant_list.tenant_id and staging.region = prod_tenant_list.data_cntr_cd#(lf)where file_id is not null #(lf)and total_duration is not null#(lf)group by #(lf)customer_id,#(lf)file_id#(lf))#(lf)#(lf)#(lf)select distinct #(lf)files.data_cntr_cd,#(lf)files.tenant_id,#(lf)prod_tenant_list.tenant_nm,#(lf)files.file_id,#(lf)concat(files.tenant_id,'.',files.file_id) as tenant_file_id,#(lf)addin_type,#(lf)file_size_bytes/1000000 as size_mb,#(lf)file_extn_nm,#(lf)tmplt_prprty_nm,#(lf)save_typ_nm,#(lf)case when task_id is not null then 'TRUE' else 'FALSE' end as task_file,#(lf)latest_refresh_date#(lf)from PROD_HARMONIZED.PRODUCT.FILE_CHANGE_LOG files #(lf)inner join maxdate on maxdate.data_cntr_cd = files.data_cntr_cd and maxdate.tenant_id = files.tenant_id and maxdate.file_id = files.file_id and maxdate.maxdate = files.eff_dts#(lf)inner join prod_tenant_list on prod_tenant_list.tenant_id = files.tenant_id and prod_tenant_list.data_cntr_cd = files.data_cntr_cd#(lf)inner join latest_refresh on latest_refresh.tenant_id = files.tenant_id and latest_refresh.file_id = files.file_id #(lf)where file_size_bytes is not null#(lf)and action_nm not in ('DELETED')#(lf)and save_typ_nm = 'FILE'#(lf)and (file_size_bytes <> 0 and file_size_bytes is not null)#(lf)#(lf)UNION ALL #(lf)#(lf)select #(lf)files.data_cntr_cd,#(lf)files.tenant_id,#(lf)tenant_nm,#(lf)files.glbl_file_id as file_id,#(lf)concat(files.tenant_id,'.',files.glbl_file_id) as tenant_file_id,#(lf)addin_type,#(lf)files.file_size_bytes/1000000 as size_mb,#(lf)files.file_extn_nm,#(lf)'Global' as tmplt_prprty_nm,#(lf)'Global' as save_typ_nm,#(lf)'Global - N/A' as task_file,#(lf)latest_refresh_date#(lf)#(lf)from PROD_HARMONIZED.PRODUCT.GLBL_FILE_DTL files#(lf)inner join prod_tenant_list on prod_tenant_list.tenant_id = files.tenant_id and prod_tenant_list.data_cntr_cd = files.data_cntr_cd#(lf)inner join latest_refresh on latest_refresh.tenant_id = files.tenant_id and latest_refresh.file_id = files.glbl_file_id#(lf)where addin_type = 'Desktop Add-in'", null, [EnableFolding=true]),
