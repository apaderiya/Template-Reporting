expression 'Project Close Dates' =
		let
		    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_POWER_USER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "--VW_IMPLEMENTATION_HOURS_DETAIL#(lf)WITH PROD_TENANT_INFO AS#(lf)(#(lf)    SELECT#(lf)        SUBSTRING(DC_TENANT_ID, 5, LENGTH(DC_TENANT_ID)) AS TENANT_ID,#(lf)        LEFT(DC_TENANT_ID,3) AS DATA_CNTR_CD,#(lf)        TENANT_NM,#(lf)        TENANT_TYP_NM,#(lf)        TENANT_ENBLD_STATUS_NM,#(lf)        account_id#(lf)    FROM PROD_HARMONIZED.PRODUCT.VW_ENBLD_PRODUCTION_TENANTS#(lf)    where account_id is not null#(lf)),#(lf)#(lf)#(lf)-- cte to acquire ARR fields#(lf)ARR AS #(lf)(#(lf)    SELECT #(lf)        AP.ACCOUNT_ID, #(lf)        ACCOUNT_NM, #(lf)        SUM(ARR_AMNT) AS TOTAL_ARR#(lf)    FROM ""PROD_HARMONIZED"".""SALES"".""VW_ACCOUNT_PROF"" AS AP#(lf)    JOIN ""PROD_HARMONIZED"".""SALES"".""VW_OPPORTUNITY_PROF"" AS OP ON OP.ACCOUNT_ID = AP.ACCOUNT_ID#(lf)#(lf)    WHERE AP.CRNT_RCRD_IND = 'Y'  #(lf)    and  OP.CRNT_RCRD_IND = 'Y'#(lf)    AND ACCOUNT_TYP_NM = 'Customer' #(lf)    AND OP.STAGE_NM = 'Closed Won'#(lf)--and arr_amnt > 0#(lf)    GROUP BY AP.ACCOUNT_ID, ACCOUNT_NM#(lf)#(lf)),#(lf)#(lf)-- cte for mt server#(lf)settings as#(lf)(#(lf)select#(lf)settings.tenant_id,#(lf)data_center,#(lf)enable_vena_365_connect_by_default,#(lf)ETL_LOAD_DATE#(lf)FROM PROD_RAW.MT_SERVER.MTSERVER_TENANT_SETTINGS_STAGING settings#(lf)inner join#(lf)(#(lf)    select#(lf)        tenant_id,#(lf)        max(etl_load_date) as maxdate#(lf)    from PROD_RAW.MT_SERVER.MTSERVER_TENANT_SETTINGS_STAGING#(lf)    group by tenant_id#(lf))maxdate#(lf)#(lf)on settings.tenant_id = maxdate.tenant_id and settings.etl_load_date = maxdate.maxdate#(lf)order by tenant_id#(lf)),#(lf)#(lf)--cte for v365 related fields#(lf)PS_HOURS AS#(lf)(#(lf)select #(lf)accounts.account_id,#(lf)accounts.account_nm, #(lf)accounts.ACCOUNT_TYP_NM,#(lf)projects.VENA_ID,#(lf)projects.project_code,#(lf)accounts.TERRITORY_SGMNT_NM, #(lf)projects.task_name, #(lf)SOW_SIGN_DATE, #(lf)GO_LIVE_DATE,#(lf)PROJECT_KICKOFF_DATE,#(lf)PROJECT_MANAGER_NAME,#(lf)project_budgeted_hours,#(lf)CUSTOMER_STATUS as client_status, #(lf)project_status, #(lf)project_phase,#(lf)V365_IMPLEMENTATION_IND,#(lf)srvcs_dlvrd_nms,#(lf)cohort_nm,#(lf)stories.stry_id,#(lf)stories.stry_title,#(lf)stories.stry_typ,#(lf)stories.stry_description,#(lf)stories.start_dt,#(lf)stories.due_dt,#(lf)year(dt_performed) as year, #(lf)weekofyear(DT_PERFORMED) as week, #(lf)sum(TIME_BOOKED_MINS)/60 as impl_hours  #(lf)#(lf)from ""PROD_PRESENTATION"".""PROFESSIONAL_SERVICES"".""VW_MAVENLINK_PROJECT_DETAILS"" projects#(lf)    #(lf)    left join ""PROD_PRESENTATION"".""PROFESSIONAL_SERVICES"".""VW_SF_ID_TO_VENA_ID_LOOKUP"" lookup on lookup.vena_id = projects.vena_id#(lf)    left join ""PROD_HARMONIZED"".""SALES"".""VW_ACCOUNT_PROF"" accounts on left(lookup.account_id, 15) = left(accounts.account_id, 15)#(lf)    left join ""PROD_PRESENTATION"".""PROFESSIONAL_SERVICES"".""VW_PROJECT_STORY_INFO"" stories on stories.VENA_PROJECT_CD = projects.PROJECT_CODE#(lf)#(lf)where ((accounts.CRNT_RCRD_IND is null) or accounts.CRNT_RCRD_IND = 'Y')#(lf)#(lf)group by #(lf)accounts.account_id,#(lf)accounts.account_nm, #(lf)accounts.ACCOUNT_TYP_NM,#(lf)projects.vena_id,#(lf)projects.project_code,#(lf)accounts.TERRITORY_SGMNT_NM, #(lf)projects.task_name, #(lf)projects.task_name, #(lf)SOW_SIGN_DATE, #(lf)GO_LIVE_DATE, #(lf)PROJECT_MANAGER_NAME,#(lf)PROJECT_KICKOFF_DATE,#(lf)project_budgeted_hours,#(lf)client_status, #(lf)project_status, #(lf)project_phase,#(lf)V365_IMPLEMENTATION_IND,#(lf)srvcs_dlvrd_nms,#(lf)cohort_nm,#(lf)stories.stry_id,#(lf)stories.stry_title,#(lf)stories.stry_typ,#(lf)stories.stry_description,#(lf)stories.start_dt,#(lf)stories.due_dt,#(lf)year(dt_performed), #(lf)weekofyear(DT_PERFORMED)#(lf)#(lf)order by accounts.account_nm, year, week#(lf)#(lf))#(lf)#(lf)SELECT #(lf)    Prod_tenant_info.tenant_ID,#(lf)    prod_tenant_info.tenant_nm,#(lf)    PS_HOURS.project_code,#(lf)    PS_HOURS.ACCOUNT_NM, #(lf)    PS_HOURS.ACCOUNT_TYP_NM,  #(lf)    PS_HOURS.TERRITORY_SGMNT_NM,#(lf)    ARR.TOTAL_ARR,#(lf)    PS_HOURS.TASK_NAME,#(lf)    SETTINGS.ENABLE_VENA_365_CONNECT_BY_DEFAULT,#(lf)    PS_HOURS.V365_IMPLEMENTATION_IND,#(lf)--    PS_HOURS.Client_STATUS,#(lf)    PS_HOURS.SOW_SIGN_DATE, #(lf)    PS_HOURS.GO_LIVE_DATE, #(lf)    PROJECT_KICKOFF_DATE,#(lf)    PS_HOURS.PROJECT_MANAGER_NAME,#(lf)    PS_HOURS.PROJECT_BUDGETED_HOURS,#(lf)    PS_HOURS.client_STATUS as customer_status, #(lf)    PS_HOURS.PROJECT_STATUS, #(lf)    PS_HOURS.PROJECT_PHASE,#(lf)    srvcs_dlvrd_nms,#(lf)    cohort_nm,#(lf)--    PS_HOURS.stry_id,#(lf)    PS_HOURS.stry_title,#(lf)--    PS_HOURS.stry_typ,#(lf)    PS_hours.start_dt,#(lf)    PS_hours.due_dt,#(lf)    PS_HOURS.stry_description,#(lf)    PS_HOURS.YEAR, #(lf)    PS_HOURS.WEEK, #(lf)    PS_HOURS.impl_hours#(lf)#(lf)#(lf)FROM PS_HOURS#(lf)INNER JOIN prod_tenant_info on PS_HOURS.account_id = prod_tenant_info.account_id#(lf)INNER JOIN settings on settings.TENANT_ID = prod_tenant_info.TENANT_ID#(lf)LEFT JOIN ARR on PS_HOURS.ACCOUNT_ID = ARR.ACCOUNT_ID#(lf)order by tenant_id, PROJECT_CODE, STRY_ID", null, [EnableFolding=true]),
		    #"Renamed Columns" = Table.RenameColumns(Source,{{"ACCOUNT_NM", "Account Name"}, {"ACCOUNT_TYP_NM", "Account Type"}, {"TOTAL_ARR", "ARR"}, {"TERRITORY_SGMNT_NM", "Territory Segment"}, {"TASK_NAME", "Project Name"}, {"SOW_SIGN_DATE", "SOW Sign Date"}, {"GO_LIVE_DATE", "Go Live Date"}, {"PROJECT_MANAGER_NAME", "Project Manager Name"}, {"PROJECT_BUDGETED_HOURS", "Project Budgeted Hours"}, {"CUSTOMER_STATUS", "Customer Status"}, {"PROJECT_STATUS", "Project Status"}, {"PROJECT_PHASE", "Project Phase"}, {"YEAR", "Year"}, {"WEEK", "Week"}, {"IMPL_HOURS", "Implementation Hours"}, {"PROJECT_KICKOFF_DATE", "Kickoff Date"}, {"ENABLE_VENA_365_CONNECT_BY_DEFAULT", "Enable V365 by Default Flag"}, {"V365_IMPLEMENTATION_IND", "V365 Implementation Indicator"}, {"TENANT_ID", "Tenant ID"}, {"TENANT_NM", "Tenant Name"}}),
		    #"Added Custom" = Table.AddColumn(#"Renamed Columns", "Time to Value Period", each [Kickoff Date]-[SOW Sign Date]),
