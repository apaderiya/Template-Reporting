_code,#(lf)    PS_HOURS.ACCOUNT_NM, #(lf)    PS_HOURS.ACCOUNT_TYP_NM,  #(lf)    PS_HOURS.TERRITORY_SGMNT_NM,#(lf)    ARR.TOTAL_ARR,#(lf)    PS_HOURS.TASK_NAME,#(lf)    SETTINGS.ENABLE_VENA_365_CONNECT_BY_DEFAULT,#(lf)    PS_HOURS.V365_IMPLEMENTATION_IND,#(lf)    PS_HOURS.Client_STATUS,#(lf)    PS_HOURS.SOW_SIGN_DATE, #(lf)    PS_HOURS.GO_LIVE_DATE, #(lf)    PROJECT_KICKOFF_DATE,#(lf)    PS_HOURS.PROJECT_MANAGER_NAME,#(lf)    PS_HOURS.PROJECT_BUDGETED_HOURS,#(lf)    PS_HOURS.client_STATUS as customer_status, #(lf)    PS_HOURS.PROJECT_STATUS, #(lf)    PS_HOURS.PROJECT_PHASE,#(lf)    PS_HOURS.stry_id,#(lf)    PS_HOURS.stry_title,#(lf)    PS_HOURS.stry_typ,#(lf)    PS_hours.start_dt,#(lf)    PS_hours.due_dt,#(lf)    PS_hours.dt_performed,#(lf)    PS_hours.assgnmnt_dts,#(lf)    PS_hours.impl_hrs,#(lf)    PS_HOURS.stry_description,#(lf)    PS_HOURS.YEAR, #(lf)    PS_HOURS.WEEK#(lf)#(lf)#(lf)FROM PS_HOURS#(lf)INNER JOIN prod_tenant_info on PS_HOURS.account_id = prod_tenant_info.account_id#(lf)INNER JOIN settings on settings.TENANT_ID = prod_tenant_info.TENANT_ID#(lf)LEFT JOIN ARR on PS_HOURS.ACCOUNT_ID = ARR.ACCOUNT_ID#(lf)order by tenant_id, PROJECT_CODE, STRY_ID", null, [EnableFolding=true]),
