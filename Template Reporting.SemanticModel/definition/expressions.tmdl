expression 'Time to Value by Project' =
		let
		    Source = Value.NativeQuery(Snowflake.Databases("vena-prod.snowflakecomputing.com","PRODUCT_MANAGER_READ_WH"){[Name="PROD_HARMONIZED"]}[Data], "WITH PROD_TENANT_INFO AS#(lf)(#(lf)    SELECT#(lf)        SUBSTRING(DC_TENANT_ID, 5, LENGTH(DC_TENANT_ID)) AS TENANT_ID,#(lf)        LEFT(DC_TENANT_ID,3) AS DATA_CNTR_CD,#(lf)        TENANT_NM,#(lf)        TENANT_TYP_NM,#(lf)        TENANT_ENBLD_STATUS_NM#(lf)    FROM ""PROD_HARMONIZED"".""PRODUCT"".""VW_ENBLD_PRODUCTION_TENANTS""#(lf)),#(lf)#(lf)#(lf)user_list as#(lf)(#(lf)SELECT #(lf)right(tenant_dc,19) as tenant_id,#(lf)user_id,#(lf)case #(lf)when ntfctn_email is not null then 'Vena Employee User' else 'Customer' end as internal_user#(lf)FROM ""PROD_HARMONIZED"".""PRODUCT"".""VW_USER_PROF""#(lf)where crnt_rcrd_ind = 'Y'#(lf)and actvtn_status_nm = 'ACTIVE'#(lf))#(lf)#(lf)#(lf)SELECT #(lf)    A.TENANT_ID,#(lf)    TENANT_NM,#(lf)    A.USER_ID,#(lf)    REQUEST_START_DTS,#(lf)    REQUEST_END_DTS,#(lf)    CASE #(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/attributes/%' THEN 'Export Attributes'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/hierarchies%' THEN 'Export Hierarchies'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/lids2%' THEN 'Export Line Item Details'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/staging%' THEN 'Export Staging'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/intersections2%' THEN 'Export Values'#(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/export/file%' THEN 'Export to File' #(lf)    WHEN A.REQUEST_ENDPOINT_NM ILIKE '%/etl/upload%' THEN 'Export to Staging Table'#(lf)    ELSE NULL END AS ENDPOINT_ACTION, #(lf)    REQUEST_ENDPOINT_NM,#(lf)    REQUEST_SIZE_B#(lf)#(lf)FROM ""PROD_HARMONIZED"".""PRODUCT"".""USER_API_ACTIVITY"" A#(lf)INNER JOIN PROD_TENANT_INFO C ON A.TENANT_ID = C.TENANT_ID#(lf)LEFT JOIN USER_LIST ON A.USER_ID = USER_LIST.USER_ID#(lf)#(lf)WHERE #(lf)#(lf)( A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/attributes/%'#(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/hierarchies%' #(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/lids2%'#(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/staging%'#(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/query/intersections2%'#(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/export/file%' #(lf)OR A.REQUEST_ENDPOINT_NM ILIKE '%/etl/upload%' )#(lf)#(lf)#(lf)and tenant_nm is not null#(lf)and request_status_cd <> '404'", null, [EnableFolding=true]),
		    #"Filtered Rows" = Table.SelectRows(Source, each ([PROJECT_STATUS] = "Closed")),
		    #"Grouped Rows" = Table.Group(#"Filtered Rows", {"TENANT_ID", "TENANT_NM", "TASK_NAME", "PROJECT_CODE", "SOW_SIGN_DATE", "STRY_ID", "STRY_TITLE"}, {{"Earliest Due Date", each List.Min([DUE_DT]), type nullable date}, {"Latest Due Date", each List.Max([DUE_DT]), type nullable date}, {"Earliest Start Date", each List.Min([START_DT]), type nullable date}, {"Latest Start Date", each List.Max([START_DT]), type nullable date}})
		in
		    #"Grouped Rows"
	lineageTag: 17b7034a-dd81-4954-8540-e79bafd997d6

