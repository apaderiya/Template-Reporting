model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-CA
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Core Dataset'

	annotation PBI_QueryGroupOrder = 1

queryGroup 'Hydra UI Refreshz'

	annotation PBI_QueryGroupOrder = 2

queryGroup 'V365 Add-in - Datasets'

	annotation PBI_QueryGroupOrder = 3

queryGroup 'Operations Table'

	annotation PBI_QueryGroupOrder = 4

annotation PBI_QueryOrder = ["Production Tenant Info","Account Summary","Hydra UI - Simple Refreshes","Dates","Date Table","Additional Tenant Info","Datadog - V365 Addin","Named ranges by template","User Detail","Summary Template Addins Tenant Info","V365 - In-Flight PS Projects","Desktop Add-in Versions","Desktop Add-in Version Usage","Hydra - Creation Timestamps","Datadog - V365 Template Creation","Desktop Add-in Modified and Saved","Template Sizes - Desktop Add-in","Tempalte Sizes Global","Template Sizes - 365 Addin","365 customers first use","Normalized Desktop Add-in Users","Old Contributor Add-in","Datadog - AdHoc Addin","Desktop Add-in Performance Report Detail","365 Performance Report Detail","Performance Report Tool Summary","AdHoc Addin - FY26 MVP","Dimesnions Customer Accounts","VW_DIM_TEMPLATE_METRICS","Agg_Hydra_SimpleRefresh_Monthly","Agg_Hydra_SimpleRefresh_Tenant_Monthly","Agg_Hydra_SimpleRefresh","_Measures","Agg_V365_Vena_Monthly","Agg_V365_Tenant_Monthly","Agg_V365_Template_Refresh","FCT Ops File Changes","FCT Ops Table Actions","DIM Ops File","DIM Tenant Ops Summary","MTSERVER_OPERATIONAL_TABLES_METRICS_STAGING"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation __TEdtr = 1

annotation PBI_ProTooling = ["DaxQueryView_Desktop","DevMode"]

annotation BestPracticeAnalyzer_IgnoreRules = {"RuleIDs":[]}

ref table 'Production Tenant Info'
